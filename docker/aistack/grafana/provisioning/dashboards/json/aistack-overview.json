              { "color": "#EAB839", "value": 65 },
              { "color": "red", "value": 85 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "GPU Utilization Over Time",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 7 },
