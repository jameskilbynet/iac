# AI Stack Test Environment Configuration
# Deploy to test VM only - safe to differ from production

# ── Environment Identity ─────────────────────────────────────────────────────
# Sets all service hostnames (e.g. chat.test.example.com)
DOMAIN=test.example.com

# Isolates container names, networks, volumes and NAS paths from production
AISTACK_NAMESPACE=aistack-test
COMPOSE_PROJECT_NAME=aistack-test
# no-gpu.yml removes CUDA device reservations from inference containers (ollama,
# comfyui, whishper) so they start without requiring the full NVIDIA driver stack.
# nvidia-gpu-exporter is intentionally NOT overridden and runs from the base config,
# allowing vGPU metrics to be scraped by Prometheus.
COMPOSE_FILE=docker-compose.yml:compose/no-gpu.yml

# ── Ollama ───────────────────────────────────────────────────────────────────
OLLAMA_API_CREDENTIALS=CHANGE_ME
OLLAMA_BASE_URL=http://ollama:11434
INFERENCE_TEXT_MODEL=llama3.1:8b
# Comma-separated list of Ollama models to pull on deploy.
# Keeping minimal for test — defaults to INFERENCE_TEXT_MODEL if not set.
OLLAMA_PULL_MODELS=llama3.1:8b,deepseek-r1:8b
INFERENCE_IMAGE_MODEL=llava

# ── Whishper ─────────────────────────────────────────────────────────────────
DB_USER=your_username
DB_PASS=your_password_here
WHISHPER_HOST=https://whishper.test.example.com
WHISPER_MODELS=tiny

# ── System ───────────────────────────────────────────────────────────────────
PUID=1000
PGID=1000

# ── Observability ────────────────────────────────────────────────────────────
GRAFANA_USER=your_username
GRAFANA_ADMIN_PASSWORD=your_password_here
OTEL_ENVIRONMENT=test
OTEL_CLUSTER=aistack-test
OTEL_COLLECTOR_ENDPOINT=http://otel-collector:4318
JAEGER_STORAGE_TYPE=badger
JAEGER_BADGER_EPHEMERAL=false
JAEGER_BADGER_CONSISTENCY=true

# ── SMB/CIFS Storage ─────────────────────────────────────────────────────────
# Points to same NAS but AISTACK_NAMESPACE above ensures separate directories
SMB_SERVER=nas.example.com
SMB_SHARE=docker
SMB_USERNAME=your_username
SMB_PASSWORD=your_password_here
# ── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_DB=aistack_test
POSTGRES_USER=your_username
POSTGRES_PASSWORD=your_password_here

# ── SearxNG ──────────────────────────────────────────────────────────────────
SEARXNG_SECRET=CHANGE_ME

# ── n8n ──────────────────────────────────────────────────────────────────────
N8N_ENCRYPTION_KEY=CHANGE_ME
N8N_USER_MANAGEMENT_JWT_SECRET=CHANGE_ME

# ── Open WebUI ───────────────────────────────────────────────────────────────
# Allow signups in test so the first admin account can be created
OPENWEBUI_ENABLE_SIGNUP=true
OPENWEBUI_DEFAULT_USER_ROLE=user

# ── Open Terminal ────────────────────────────────────────────────────────────
OPEN_TERMINAL_API_KEY=CHANGE_ME

# ── Langfuse ─────────────────────────────────────────────────────────────────
LANGFUSE_BASE_URL="https://langfuse.test.example.com"
LANGFUSE_NEXTAUTH_SECRET=CHANGE_ME
LANGFUSE_SALT=76b9a0a91b7b1c98709879e40486105c
LANGFUSE_ENCRYPTION_KEY=CHANGE_ME
LANGFUSE_SECRET_KEY=CHANGE_ME
LANGFUSE_PUBLIC_KEY=CHANGE_ME
# Bootstrap: creates admin user on first start — change password after login
LANGFUSE_INIT_USER_EMAIL=user@example.com
LANGFUSE_INIT_USER_NAME=James
LANGFUSE_INIT_USER_PASSWORD=your_password_here

# ── MinIO ─────────────────────────────────────────────────────────────────────
MINIO_ROOT_USER=your_username
MINIO_ROOT_PASSWORD=your_password_here

# ── ClickHouse ────────────────────────────────────────────────────────────────
CLICKHOUSE_PASSWORD=your_password_here

# ── Backup ────────────────────────────────────────────────────────────────────
BACKUP_RETENTION_DAYS=3
BACKUP_COMPRESS=true