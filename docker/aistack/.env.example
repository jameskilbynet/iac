# AI Stack Configuration
# ── Instance identity (must match across both variables) ─────────────────────
AISTACK_NAMESPACE=aistack
COMPOSE_PROJECT_NAME=aistack
COMPOSE_FILE=docker-compose.yml:compose/kuma-labels.yml

# ── Domain ───────────────────────────────────────────────────────────────────
DOMAIN=example.com

# ── Ollama ───────────────────────────────────────────────────────────────────
OLLAMA_API_CREDENTIALS=your_credentials_here
INFERENCE_TEXT_MODEL=llama3.1:8b
INFERENCE_IMAGE_MODEL=llava
OLLAMA_PULL_MODELS=llama3.1:8b,llava:13b

# ── Whishper ─────────────────────────────────────────────────────────────────
WHISPER_MODELS=tiny,small
MONGO_ROOT_USERNAME=your_username
MONGO_ROOT_PASSWORD=your_password_here

# ── System ───────────────────────────────────────────────────────────────────
PUID=1000
PGID=1000

# ── Observability ────────────────────────────────────────────────────────────
GRAFANA_USER=your_username
GRAFANA_ADMIN_PASSWORD=your_password_here
GRAFANA_DB=grafana
OTEL_ENVIRONMENT=homelab
OTEL_CLUSTER=aistack

# ── SMB/CIFS Storage ─────────────────────────────────────────────────────────
SMB_SERVER=192.168.x.x
SMB_SHARE=your_share_name
SMB_USERNAME=your_username
SMB_PASSWORD=your_password_here

# ── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_DB=aistack
POSTGRES_USER=your_username
POSTGRES_PASSWORD=your_password_here

# ── SearxNG ──────────────────────────────────────────────────────────────────
SEARXNG_SECRET=your_secret_key_here

# ── n8n ──────────────────────────────────────────────────────────────────────
N8N_DB=n8n
N8N_ENCRYPTION_KEY=your_secret_key_here
N8N_USER_MANAGEMENT_JWT_SECRET=your_secret_key_here

# ── Open Terminal ────────────────────────────────────────────────────────────
OPEN_TERMINAL_API_KEY=your_secret_key_here

# ── Langfuse ─────────────────────────────────────────────────────────────────
# Bootstrap: creates admin user on first start — change password after login
LANGFUSE_INIT_USER_EMAIL=your_username
LANGFUSE_INIT_USER_NAME=your_username
LANGFUSE_INIT_USER_PASSWORD=your_password_here
LANGFUSE_NEXTAUTH_SECRET=your_secret_key_here
LANGFUSE_SALT=your_langfuse_salt_here
LANGFUSE_ENCRYPTION_KEY=your_secret_key_here
LANGFUSE_SECRET_KEY=your_secret_key_here
LANGFUSE_PUBLIC_KEY=your_secret_key_here
# LANGFUSE_BASE_URL defaults to https://langfuse.${DOMAIN} — only set to override
# LANGFUSE_BASE_URL=https://langfuse.example.com

# ── MinIO ─────────────────────────────────────────────────────────────────────
MINIO_ROOT_USER=your_username
MINIO_ROOT_PASSWORD=your_password_here

# ── ClickHouse ────────────────────────────────────────────────────────────────
CLICKHOUSE_PASSWORD=your_password_here
AISTACK_INTERNAL_SUBNET=172.30.1.0/24
