# AI Stack Configuration
OLLAMA_API_CREDENTIALS=your_credentials_here
OLLAMA_BASE_URL=https://service.example.com
INFERENCE_TEXT_MODEL=llama3.1:8b
INFERENCE_IMAGE_MODEL=llava
DB_USER=your_username
DB_PASS=your_password_here
WHISHPER_HOST=your_hostname
WHISPER_MODELS=tiny,small
PUID=1000
PGID=1000

# Hoarder Configuration
DATA_DIR=/data
MEILI_ADDR=http://meilisearch:7700
MEILI_MASTER_KEY=your_secret_key_here
NEXTAUTH_URL=https://service.example.com
HOARDER_VERSION=release
NEXTAUTH_SECRET=your_secret_key_here

# Observability Configuration
GRAFANA_USER=your_username
GRAFANA_PASSWORD=your_password_here

# OpenTelemetry Configuration
OTEL_ENVIRONMENT=homelab
OTEL_CLUSTER=aistack
OTEL_COLLECTOR_ENDPOINT=http://otel-collector:4318

# Jaeger Configuration
JAEGER_STORAGE_TYPE=badger
JAEGER_BADGER_EPHEMERAL=false
JAEGER_BADGER_CONSISTENCY=true

# SMB/CIFS Storage Configuration
SMB_SERVER=192.168.x.x
SMB_SHARE=your_share_name
SMB_USERNAME=your_username
SMB_PASSWORD=your_password_here

# PostgreSQL Configuration
POSTGRES_DB=aistack
POSTGRES_USER=your_username
POSTGRES_PASSWORD=your_password_here

# SearxNG Configuration
SEARXNG_SECRET=your_secret_key_here

# n8n Configuration
N8N_ENCRYPTION_KEY=your_secret_key_here
N8N_USER_MANAGEMENT_JWT_SECRET=your_secret_key_here

# Open Terminal Configuration
OPEN_TERMINAL_API_KEY=your_secret_key_here

# Backup Configuration
BACKUP_RETENTION_DAYS=7
BACKUP_COMPRESS=true
